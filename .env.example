# Required
OPENAI_API_KEY=sk-...           # Embeddings (text-embedding-3-small, 768-dim)
ANTHROPIC_API_KEY=sk-ant-...    # Claude code generation

# Optional
RUBIX_DATA_DIR=./data           # Data directory
RUBIX_MODEL=claude-opus-4-5-20250514  # Claude model
RUBIX_ULTRATHINK=true           # Extended thinking
RUBIX_MAX_PARALLEL=5            # Parallel engineer count
TELEGRAM_BOT_TOKEN=             # Telegram bot + AFK remote control
WEBHOOK_PORT=3456               # Webhook server port

# Multi-project (set per MCP instance in .claude/mcp.json env)
# RUBIX_PROJECT_ROOT=/path/to/project
# RUBIX_PROJECT_NAME=My Project
# RUBIX_CORE_BRAIN_DATA_DIR=./data/core-brain
